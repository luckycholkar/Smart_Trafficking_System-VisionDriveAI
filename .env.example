# VisionDrive AI - environment overrides
# Copy to `.env` and adjust. Values here override config.yaml.
# All keys are namespaced with VISIONDRIVE_ and use __ to nest.

# --- Runtime ---
VISIONDRIVE_ENV=dev                       # dev | prod
VISIONDRIVE_LOG_LEVEL=INFO

# --- API / dashboard ---
VISIONDRIVE_API__HOST=127.0.0.1
VISIONDRIVE_API__PORT=5000

# --- Video / model paths (override config.yaml defaults) ---
# VISIONDRIVE_VIDEO__PATH=data/videos/traffic.mp4
# VISIONDRIVE_MODEL__WEIGHTS_PATH=data/weights/yolov8n.pt

# --- Feature flags ---
# VISIONDRIVE_FEATURES__ENABLE_HELMET=false
# VISIONDRIVE_FEATURES__ENABLE_ACCIDENT=false
# VISIONDRIVE_FEATURES__ENABLE_SMS=false
# VISIONDRIVE_FEATURES__DISPLAY_WINDOW=true

# --- Twilio SMS (only used when features.enable_sms=true) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=
EMERGENCY_PHONE=
